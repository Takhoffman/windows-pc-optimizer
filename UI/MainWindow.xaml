<Window x:Class="Velocity.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Velocity — Gaming PC Optimizer"
        Width="1180" Height="760" MinWidth="940" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" ResizeMode="CanResize"
        Background="{StaticResource Bg}"
        FontFamily="{StaticResource UiFont}"
        MaxHeight="{x:Static SystemParameters.MaximizedPrimaryScreenHeight}"
        TextOptions.TextRenderingMode="ClearType">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="44" ResizeBorderThickness="6" GlassFrameThickness="0" CornerRadius="0"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ======================= Sidebar ======================= -->
        <Border Grid.Column="0" Background="{StaticResource Surface}"
                BorderBrush="{StaticResource Stroke}" BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- Logo -->
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="24,22,0,26">
                    <Border Width="32" Height="32" CornerRadius="9" Background="{StaticResource AccentGradient}">
                        <TextBlock Text="&#xE945;" FontFamily="{StaticResource IconFont}" FontSize="16"
                                   Foreground="#0A0D14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Margin="11,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="VELOCITY" FontSize="15" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"
                                   FontFamily="{StaticResource UiFont}"/>
                        <TextBlock Text="Gaming PC Optimizer" FontSize="10" Foreground="{StaticResource TextTertiary}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Footer -->
                <StackPanel DockPanel.Dock="Bottom" Margin="24,0,24,18">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xEA18;" Style="{StaticResource Icon}" FontSize="12" Foreground="{StaticResource Success}"/>
                        <TextBlock Text="Administrator" Margin="7,0,0,0" FontSize="11" Foreground="{StaticResource TextSecondary}"/>
                    </StackPanel>
                    <TextBlock Text="v1.0.0 · every change is revertible" FontSize="10.5" Foreground="{StaticResource TextTertiary}" Margin="0,6,0,0"/>
                </StackPanel>

                <!-- Nav -->
                <StackPanel>
                    <RadioButton x:Name="NavDashboard" Style="{StaticResource NavButton}" Tag="&#xE80F;"
                                 Content="Dashboard" IsChecked="True" Checked="Nav_Checked"/>
                    <RadioButton x:Name="NavTweaks" Style="{StaticResource NavButton}" Tag="&#xE9E9;"
                                 Content="Tweaks" Checked="Nav_Checked"/>
                    <RadioButton x:Name="NavProfiles" Style="{StaticResource NavButton}" Tag="&#xE7FC;"
                                 Content="Game Profiles" Checked="Nav_Checked"/>
                    <RadioButton x:Name="NavRestore" Style="{StaticResource NavButton}" Tag="&#xE81C;"
                                 Content="Backup &amp; Restore" Checked="Nav_Checked"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ======================= Content ======================= -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <DockPanel Grid.Row="0" LastChildFill="False">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Style="{StaticResource WindowControlButton}" Content="&#xE921;"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True" Click="Minimize_Click"/>
                    <Button x:Name="MaxRestoreButton" Style="{StaticResource WindowControlButton}" Content="&#xE922;"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True" Click="MaxRestore_Click"/>
                    <Button Style="{StaticResource CloseButton}" Content="&#xE8BB;"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True" Click="Close_Click"/>
                </StackPanel>
            </DockPanel>

            <!-- Pages -->
            <Grid Grid.Row="1" Margin="34,4,34,26">

                <!-- ==================== Dashboard ==================== -->
                <ScrollViewer x:Name="DashboardPanel" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Dashboard" Style="{StaticResource PageTitle}"/>
                        <TextBlock Text="Your system at a glance. Velocity only runs while this window is open — nothing stays behind eating frames."
                                   Style="{StaticResource PageSubtitle}" Margin="0,6,0,20"/>

                        <!-- Restart banner -->
                        <Border Background="{StaticResource WarningSoft}" BorderBrush="{StaticResource Warning}"
                                BorderThickness="1" CornerRadius="12" Padding="16,12" Margin="0,0,0,16"
                                Visibility="{Binding RestartRecommended, Converter={StaticResource BoolToVis}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE7BA;" Style="{StaticResource Icon}" Foreground="{StaticResource Warning}" FontSize="15"/>
                                <TextBlock Margin="10,0,0,0" VerticalAlignment="Center" FontSize="12.5"
                                           Foreground="{StaticResource TextPrimary}"
                                           Text="Some changes need a restart (or sign-out) to fully take effect."/>
                            </StackPanel>
                        </Border>

                        <!-- Hero -->
                        <Border CornerRadius="16" Padding="28,24" Margin="0,0,0,16">
                            <Border.Background>
                                <StaticResource ResourceKey="HeroGradient"/>
                            </Border.Background>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Ready to boost your FPS?" FontSize="20" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimary}"/>
                                    <TextBlock Margin="0,7,24,0" FontSize="12.5" TextWrapping="Wrap"
                                               Foreground="{StaticResource TextSecondary}"
                                               Text="Apply every optimization in one click, or pick a profile tuned for the games you play. Velocity snapshots the original value of every setting before touching it."/>
                                    <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                                        <Button Content="Apply Max Performance" Style="{StaticResource PrimaryButton}"
                                                Command="{Binding ApplyMaxCommand}"/>
                                        <Button Content="Revert everything" Style="{StaticResource GhostButton}" Margin="10,0,0,0"
                                                Command="{Binding RevertAllCommand}"/>
                                    </StackPanel>
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="&#xE945;" FontFamily="{StaticResource IconFont}"
                                           FontSize="64" VerticalAlignment="Center" Margin="0,0,10,0"
                                           Foreground="{StaticResource AccentGradient}" Opacity="0.9"/>
                            </Grid>
                        </Border>

                        <!-- Stats -->
                        <UniformGrid Columns="3">
                            <Border Style="{StaticResource CardStyle}" Margin="0,0,8,0">
                                <StackPanel>
                                    <TextBlock Text="OPTIMIZATIONS ACTIVE" FontSize="10.5" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextTertiary}"/>
                                    <TextBlock Text="{Binding AppliedSummary}" FontSize="24" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimary}" Margin="0,8,0,10"/>
                                    <ProgressBar Style="{StaticResource AccentProgress}" Minimum="0" Maximum="1"
                                                 Value="{Binding AppliedFraction, Mode=OneWay}"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource CardStyle}" Margin="4,0,4,0">
                                <StackPanel>
                                    <TextBlock Text="ACTIVE POWER PLAN" FontSize="10.5" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextTertiary}"/>
                                    <TextBlock Text="{Binding PowerPlanName}" FontSize="17" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimary}" Margin="0,10,0,0"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="Ultimate Performance recommended" FontSize="11"
                                               Foreground="{StaticResource TextSecondary}" Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource CardStyle}" Margin="8,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="SAFETY NET" FontSize="10.5" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextTertiary}"/>
                                    <TextBlock Text="{Binding Backups.Count}" FontSize="24" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimary}" Margin="0,8,0,0"/>
                                    <TextBlock Text="original settings backed up and ready to restore" FontSize="11"
                                               TextWrapping="Wrap" Foreground="{StaticResource TextSecondary}" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                    </StackPanel>
                </ScrollViewer>

                <!-- ==================== Tweaks ==================== -->
                <ScrollViewer x:Name="TweaksPanel" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="Tweaks" Style="{StaticResource PageTitle}"/>
                        <TextBlock Text="Flip any switch on or off. The original value is snapshotted before every change."
                                   Style="{StaticResource PageSubtitle}" Margin="0,6,0,14"/>

                        <ItemsControl ItemsSource="{Binding Groups}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,10,0,4">
                                        <TextBlock Text="{Binding Category}" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{StaticResource Accent}" Margin="2,0,0,10"/>
                                        <ItemsControl ItemsSource="{Binding Tweaks}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Style="{StaticResource CardStyle}" Padding="18,14" Margin="0,0,0,8">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <TextBlock Text="{Binding Name}" FontSize="13.5" FontWeight="SemiBold"
                                                                               Foreground="{StaticResource TextPrimary}"/>
                                                                    <Border CornerRadius="999" Padding="7,2" Margin="8,0,0,0"
                                                                            VerticalAlignment="Center"
                                                                            Visibility="{Binding ShowRisk, Converter={StaticResource BoolToVis}}">
                                                                        <Border.Style>
                                                                            <Style TargetType="Border">
                                                                                <Setter Property="Background" Value="{StaticResource WarningSoft}"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsAdvanced}" Value="True">
                                                                                        <Setter Property="Background" Value="#26F87171"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Border.Style>
                                                                        <TextBlock Text="{Binding RiskLabel}" FontSize="10" FontWeight="SemiBold">
                                                                            <TextBlock.Style>
                                                                                <Style TargetType="TextBlock">
                                                                                    <Setter Property="Foreground" Value="{StaticResource Warning}"/>
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding IsAdvanced}" Value="True">
                                                                                            <Setter Property="Foreground" Value="{StaticResource Danger}"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </TextBlock.Style>
                                                                        </TextBlock>
                                                                    </Border>
                                                                    <Border Background="{StaticResource AccentSoft}" CornerRadius="999"
                                                                            Padding="7,2" Margin="6,0,0,0" VerticalAlignment="Center"
                                                                            Visibility="{Binding ShowReboot, Converter={StaticResource BoolToVis}}">
                                                                        <TextBlock Text="{Binding RebootLabel}" FontSize="10" FontWeight="SemiBold"
                                                                                   Foreground="{StaticResource Accent}"/>
                                                                    </Border>
                                                                </StackPanel>
                                                                <TextBlock Text="{Binding Description}" FontSize="12" TextWrapping="Wrap"
                                                                           Foreground="{StaticResource TextSecondary}" Margin="0,4,0,0"/>
                                                            </StackPanel>
                                                            <ToggleButton Grid.Column="1" Style="{StaticResource ToggleSwitch}"
                                                                          VerticalAlignment="Center"
                                                                          IsChecked="{Binding IsOn, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                          IsEnabled="{Binding DataContext.IsIdle, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>

                <!-- ==================== Profiles ==================== -->
                <ScrollViewer x:Name="ProfilesPanel" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="Game Profiles" Style="{StaticResource PageTitle}"/>
                        <TextBlock Text="Curated tweak bundles for how you actually play. Games detected on this PC glow cyan."
                                   Style="{StaticResource PageSubtitle}" Margin="0,6,0,18"/>

                        <ItemsControl ItemsSource="{Binding Profiles}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource CardStyle}" Width="392" Margin="0,0,14,14">
                                        <StackPanel>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Width="38" Height="38" CornerRadius="10" Background="{StaticResource AccentSoft}">
                                                    <TextBlock Text="{Binding IconGlyph}" FontFamily="{StaticResource IconFont}"
                                                               FontSize="17" Foreground="{StaticResource Accent}"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold"
                                                               Foreground="{StaticResource TextPrimary}"/>
                                                    <TextBlock Text="{Binding CoverageText}" FontSize="11"
                                                               Foreground="{StaticResource TextTertiary}" Margin="0,2,0,0"/>
                                                </StackPanel>
                                                <Border Grid.Column="2" Background="#1A34D399" CornerRadius="999" Padding="8,3"
                                                        VerticalAlignment="Center"
                                                        Visibility="{Binding IsFullyApplied, Converter={StaticResource BoolToVis}}">
                                                    <TextBlock Text="ACTIVE" FontSize="9.5" FontWeight="Bold"
                                                               Foreground="{StaticResource Success}"/>
                                                </Border>
                                            </Grid>
                                            <TextBlock Text="{Binding Tagline}" FontSize="12" TextWrapping="Wrap"
                                                       Foreground="{StaticResource TextSecondary}" Margin="0,12,0,0"/>
                                            <ItemsControl ItemsSource="{Binding Games}" Margin="0,12,0,0"
                                                          Visibility="{Binding HasGames, Converter={StaticResource BoolToVis}}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Style="{StaticResource ChipStyle}">
                                                            <Border.Resources>
                                                                <Style TargetType="Border" BasedOn="{StaticResource ChipStyle}"/>
                                                            </Border.Resources>
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="&#xE73E;" FontFamily="{StaticResource IconFont}" FontSize="9"
                                                                           Foreground="{StaticResource Accent}" VerticalAlignment="Center"
                                                                           Margin="0,0,5,0"
                                                                           Visibility="{Binding IsInstalled, Converter={StaticResource BoolToVis}}"/>
                                                                <TextBlock Text="{Binding Name}" FontSize="11" VerticalAlignment="Center">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsInstalled}" Value="True">
                                                                                    <Setter Property="Foreground" Value="{StaticResource Accent}"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <Button Content="Apply profile" Style="{StaticResource PrimaryButton}"
                                                    HorizontalAlignment="Left" Margin="0,14,0,0"
                                                    Command="{Binding ApplyCommand}"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>

                <!-- ==================== Backup & Restore ==================== -->
                <ScrollViewer x:Name="RestorePanel" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Backup &amp; Restore" Style="{StaticResource PageTitle}"/>
                                <TextBlock Text="Every setting Velocity changes is captured here first. Revert one, or everything, any time."
                                           Style="{StaticResource PageSubtitle}" Margin="0,6,0,18"/>
                            </StackPanel>
                            <Button Grid.Column="1" Content="Revert everything" Style="{StaticResource GhostButton}"
                                    VerticalAlignment="Top" Command="{Binding RevertAllCommand}"/>
                        </Grid>

                        <TextBlock FontSize="12.5" Foreground="{StaticResource TextTertiary}" Margin="2,20,0,0"
                                   Text="Nothing to restore yet — apply a tweak or a profile and its original value will appear here.">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasBackups}" Value="False">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <ItemsControl ItemsSource="{Binding Backups}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource CardStyle}" Padding="18,14" Margin="0,0,0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="&#xE81C;" Style="{StaticResource Icon}" FontSize="16"
                                                       Foreground="{StaticResource Accent}" Margin="0,0,14,0"/>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimary}"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                    <TextBlock Text="{Binding SavedAt}" FontSize="11" Foreground="{StaticResource TextTertiary}"/>
                                                    <TextBlock Text=" · " FontSize="11" Foreground="{StaticResource TextTertiary}"/>
                                                    <TextBlock Text="{Binding Detail}" FontSize="11" Foreground="{StaticResource TextTertiary}"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <Button Grid.Column="2" Content="Revert" Style="{StaticResource GhostButton}"
                                                    Padding="14,7" VerticalAlignment="Center"
                                                    Command="{Binding RevertCommand}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!-- ======================= Busy overlay ======================= -->
        <Grid Grid.ColumnSpan="2" Background="#B30A0D14"
              Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
            <Border Style="{StaticResource CardStyle}" HorizontalAlignment="Center" VerticalAlignment="Center"
                    Padding="34,26" MinWidth="320">
                <StackPanel>
                    <TextBlock Text="{Binding BusyText}" FontSize="13.5" FontWeight="Medium"
                               Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Center"/>
                    <ProgressBar IsIndeterminate="True" Height="4" Margin="0,16,0,0"
                                 Foreground="{StaticResource Accent}" Background="{StaticResource Surface}"
                                 BorderThickness="0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
