# Normalize text to LF in the repo; Git converts to the platform's line ending on checkout.
* text=auto

# Binary assets: never apply line-ending conversion (corrupts them).
*.ico   binary
*.bmp   binary
*.png   binary
*.rtf   binary
*.msi   binary

# Keep shell/script tooling stable regardless of the cloning platform.
*.ps1   text eol=crlf
*.cs    text
*.xaml  text
*.wxs   text
*.md    text
